NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aicentralize?schema=public"
JWT_SECRET="replace-with-secure-secret"
# Public origin of the web app, used to build invitation links in emails.
# In production set this to the deployed web origin, e.g. https://web-production-xxxx.up.railway.app
APP_PUBLIC_URL="http://localhost:5175"
# Optional alias; APP_PUBLIC_URL takes precedence if both are set.
WEB_PUBLIC_URL=""
OLLAMA_BASE_URL="http://127.0.0.1:11434"
AI_PRIMARY_PROVIDER="ollama"
AI_FALLBACK_PROVIDER=""
AI_REQUEST_TIMEOUT_MS=120000
OPENAI_BASE_URL="https://api.openai.com"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
ANTHROPIC_BASE_URL="https://api.anthropic.com"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-5-haiku-latest"
GEMINI_BASE_URL="https://generativelanguage.googleapis.com"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
# Optional remote ASR/Whisper service for production (POST /transcribe with multipart audio).
# Deploy apps/asr as a separate Railway service, then point API to it.
# See docs/railway-asr-service.md
ASR_BASE_URL=""
ASR_API_KEY=""
# Remote ASR/Whisper timeout in ms (21600000 = 6 hours). nginx `/ai/` proxy uses 22200s — keep nginx above this.
ASR_REQUEST_TIMEOUT_MS=21600000
# Multipart upload max bytes (524288000 = 500 MB). Align with nginx client_max_body_size and ASR_MAX_UPLOAD_BYTES.
MAX_UPLOAD_BYTES=524288000
PYTHON_EXECUTABLE=""
SYSTEM_SETTINGS_ENCRYPTION_KEY=""
REMINDER_CRON="*/30 * * * *"
REMINDER_LOOKAHEAD_HOURS=24
REMINDER_DEDUPE_HOURS=24
REMINDER_OVERDUE_SHORT_AFTER_HOURS=24
REMINDER_OVERDUE_ESCALATE_AFTER_HOURS=72
REMINDER_OVERDUE_SHORT_INTERVAL_HOURS=24
REMINDER_OVERDUE_ESCALATE_INTERVAL_HOURS=48
REMINDER_ESCALATION_FALLBACK_EMAIL=""
AI_SIMILARITY_THRESHOLD=0.2
SMTP_HOST="smtp.your-org.local"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE=false
MAIL_FROM="Kora <noreply@your-org.local>"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@your-org.local"
