# Docker deployment environment
# Copy to .env.production and set secure values before deploy.

# App
PORT=4000
JWT_SECRET=replace-with-strong-secret
OLLAMA_BASE_URL=http://ollama:11434
REMINDER_CRON=*/30 * * * *
REMINDER_LOOKAHEAD_HOURS=24
REMINDER_DEDUPE_HOURS=24
REMINDER_OVERDUE_SHORT_AFTER_HOURS=24
REMINDER_OVERDUE_ESCALATE_AFTER_HOURS=72
REMINDER_OVERDUE_SHORT_INTERVAL_HOURS=24
REMINDER_OVERDUE_ESCALATE_INTERVAL_HOURS=48
REMINDER_ESCALATION_FALLBACK_EMAIL=
AI_SIMILARITY_THRESHOLD=0.2

# PostgreSQL container
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-db-password
POSTGRES_DB=aicentralize
POSTGRES_PORT=5432

# Notification channels (optional)
SMTP_HOST=smtp.your-org.local
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM=AI Centralize <noreply@your-org.local>
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@your-org.local
