generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  PM
  MEMBER
}

enum SystemRole {
  SUPER_ADMIN
  MODERATOR
  USER
}

enum TenantRole {
  TENANT_ADMIN
  MANAGER
  MEMBER
  VIEWER
}

enum TenantEntityType {
  ORGANIZATION
  INDIVIDUAL
}

enum TenantBillingStatus {
  PENDING_ACTIVATION
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum TenantBillingEventType {
  ACTIVATED
  PERIOD_OPENED
  PAYMENT_SUBMITTED
  PAYMENT_APPROVED
  PAYMENT_REJECTED
  PACKAGE_CHANGED
  MARKED_PAST_DUE
}

enum TenantBillingPeriodStatus {
  OPEN
  AWAITING_PAYMENT
  PAID
  PAST_DUE
  VOID
}

enum TenantBillingPaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ActionStatus {
  OPEN
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum ReminderType {
  UPCOMING
  OVERDUE
  REASSIGNED
  DUE_DATE_CHANGED
  STATUS_CHANGED
  PRIORITY_CHANGED
}

enum ReminderLogType {
  DUE_SOON
  OVERDUE
  OVERDUE_SHORT
  OVERDUE_ESCALATE
}

enum ReminderDeliveryStatus {
  SENT
  SKIPPED
  FAILED
}

enum KnowledgeChunkSourceType {
  MINUTE_SUMMARY
  KEY_POINT
  DECISION
  ACTION_ITEM
  MEETING_METADATA
}

enum MeetingParticipantRole {
  ORGANIZER
  ATTENDEE
  OBSERVER
}

enum MeetingStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum MeetingAttendanceStatus {
  INVITED
  ATTENDED
  ABSENT
  LATE
}

enum MeetingArtifactType {
  TRANSCRIPT
  RAW_NOTE
  AUDIO
  FILE
  AUDIO_FILE
  DOCUMENT
  OTHER
}

enum MeetingArtifactSourceType {
  VOICE_CAPTURE
  MANUAL_PASTE
  FILE_UPLOAD
  IMPORT
  OTHER
}

enum MinuteDraftStatus {
  DRAFT
  READY_FOR_REVIEW
  REJECTED
  SUPERSEDED
  READY
  FAILED
}

enum MinuteDraftGeneratedBy {
  AI
  USER
  HYBRID
}

enum MinuteVersionStatus {
  APPROVED
  REVOKED
  ARCHIVED
}

enum DecisionStatus {
  ACTIVE
  SUPERSEDED
  CANCELLED
}

enum ActionItemSource {
  MANUAL
  AI_EXTRACTED
  AI_DRAFT
  APPROVED_MINUTE
}

enum ActionItemPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ProjectKnowledgeSourceType {
  TOR
  PROPOSAL
  CONTRACT
  REQUIREMENT
  MINUTES
  ACTION_LOG
  RISK_LOG
  ISSUE_LOG
  TIMELINE
  TECHNICAL_NOTE
  OTHER
}

enum ProjectKnowledgeAuthorityLevel {
  AUTHORITATIVE
  SUPPORTING
  HISTORICAL
}

enum ProjectKnowledgeSourceStatus {
  UPLOADED
  EXTRACTED
  REVIEWED
  APPROVED
  REJECTED
}

enum KnowledgeImportJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum KnowledgeImportJobKind {
  IMPORT
  EXTRACT
}

enum ProjectMemoryItemType {
  OVERVIEW
  SCOPE
  REQUIREMENT
  DECISION
  RISK
  ISSUE
  ACTION
  MILESTONE
  GLOSSARY
  ASSUMPTION
  OPEN_QUESTION
  STAKEHOLDER
}

enum ProjectMemoryItemStatus {
  DRAFT
  APPROVED
  REJECTED
  SUPERSEDED
}

enum ProjectGeneralNoteVisibility {
  PUBLIC
  PRIVATE
}

enum AiRunOperation {
  MINUTE_EXTRACTION
  RETRIEVAL_QUERY
  ASK_AI_ANSWER
  REMINDER_RUN
  MORNING_BRIEFING
  FEELING_LOG_ANALYSIS
}

enum AiRunStatus {
  SUCCESS
  FAILED
}

enum SentimentProcessingStatus {
  PENDING
  PROCESSED
  SKIPPED
  FAILED
}

enum CommunicationSentimentSourceType {
  ASK_AI_QUERY
  MEETING_TRANSCRIPT
  COMMENT
  MORNING_BRIEFING_ACK
}

enum FeelingLogAnalysisAudience {
  PERSONAL
  LEADERSHIP
  MENTION_TARGET
}

enum MorningBriefingStatus {
  GENERATED
  FAILED
}

enum MorningBriefingAckMood {
  GOT_IT
  I_KNOW
  RUDENESS
}

enum CommunicationMoodState {
  CALM
  NEEDS_ATTENTION
  HIGH_PRESSURE
  INSUFFICIENT_DATA
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String
  nickname      String?
  phone         String?
  passwordHash  String
  mustChangePassword Boolean @default(false)
  isActive      Boolean      @default(true)
  role          UserRole     @default(MEMBER)
  systemRole    SystemRole   @default(USER)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  assignedItems ActionItem[] @relation("ActionAssignee")
  createdMeetings Meeting[]  @relation("MeetingCreator")
  notifications Notification[]
  notificationSetting NotificationSetting?
  pushSubscriptions PushSubscription[]
  refreshTokens RefreshToken[]
  meetingParticipants MeetingParticipant[]
  meetingArtifacts MeetingArtifact[]
  minuteDraftsCreated MinuteDraft[]
  approvedMinuteVersions MinuteVersion[] @relation("MinuteVersionApprover")
  decisionsOwned Decision[] @relation("DecisionOwner")
  actionItemStatusHistory ActionItemStatusHistory[] @relation("ActionItemStatusChangedBy")
  reminderLogs ReminderLog[]
  askAiQueryLogs AskAiQueryLog[]
  communicationSentimentSnapshots CommunicationSentimentSnapshot[] @relation("MemberSentimentSnapshots")
  morningBriefings MorningBriefing[] @relation("MorningBriefingUser")
  morningBriefingAcknowledgements MorningBriefingAcknowledgement[] @relation("MorningBriefingAckUser")
  feelingLogsAuthored FeelingLog[] @relation("FeelingLogAuthor")
  feelingLogMentions FeelingLogMention[] @relation("FeelingLogMentionTarget")
  feelingLogAnalysisTargets FeelingLogAnalysis[] @relation("FeelingLogAnalysisTarget")
  aiRunLogs AiRunLog[]
  projectKnowledgeSourcesUploaded ProjectKnowledgeSource[] @relation("ProjectKnowledgeSourceUploader")
  projectMemoryItemsApproved ProjectMemoryItem[] @relation("ProjectMemoryItemApprover")
  projectGeneralNotesAuthored ProjectGeneralNote[] @relation("ProjectGeneralNoteAuthor")
  projectKnowledgeImportJobs ProjectKnowledgeImportJob[]
  tenantMemberships TenantMembership[]
  createdTenants Tenant[] @relation("TenantCreator")
  activatedTenants Tenant[] @relation("TenantActivatedBy")
  systemSettingsUpdates SystemSettings[]
  invitationsCreated UserInvitation[] @relation("InvitationCreator")
  invitationsAccepted UserInvitation[] @relation("InvitationAcceptedUser")
  billingEventsActed TenantBillingEvent[] @relation("BillingEventActor")
  billingPaymentsSubmitted TenantBillingPayment[] @relation("BillingPaymentSubmittedBy")
  billingPaymentsReviewed TenantBillingPayment[] @relation("BillingPaymentReviewedBy")
}

model SystemSettings {
  id          String   @id @default("global")
  config      Json
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  updatedBy   User?    @relation(fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([updatedAt])
}

model Tenant {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  isActive    Boolean  @default(true)
  entityType  TenantEntityType @default(ORGANIZATION)
  tenantCategoryId String?
  currentPackageId String?
  billingStatus TenantBillingStatus @default(PENDING_ACTIVATION)
  billingStartDate DateTime?
  billingTimezone String @default("Asia/Bangkok")
  currentPeriodStart DateTime?
  currentPeriodEnd DateTime?
  activatedAt DateTime?
  activatedByUserId String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantCategory TenantCategory? @relation(fields: [tenantCategoryId], references: [id], onDelete: SetNull)
  currentPackage SubscriptionPackage? @relation(fields: [currentPackageId], references: [id], onDelete: SetNull)
  createdBy   User     @relation("TenantCreator", fields: [createdById], references: [id], onDelete: Restrict)
  activatedBy User?    @relation("TenantActivatedBy", fields: [activatedByUserId], references: [id], onDelete: SetNull)
  memberships TenantMembership[]
  projects    Project[]
  invitations UserInvitation[]
  projectKnowledgeSources ProjectKnowledgeSource[]
  projectMemoryItems ProjectMemoryItem[]
  projectGeneralNotes ProjectGeneralNote[]
  communicationSentimentSnapshots CommunicationSentimentSnapshot[]
  morningBriefings MorningBriefing[]
  feelingLogs FeelingLog[] @relation("FeelingLogTenant")
  billingEvents TenantBillingEvent[]
  billingPeriods TenantBillingPeriod[]
  billingPayments TenantBillingPayment[]

  @@index([createdAt])
  @@index([currentPackageId])
  @@index([billingStatus])
  @@index([billingStartDate])
  @@index([activatedByUserId])
  @@index([entityType, tenantCategoryId])
}

model TenantCategory {
  id         String           @id @default(cuid())
  code       String           @unique
  name       String
  entityType TenantEntityType
  sortOrder  Int              @default(0)
  isActive   Boolean          @default(true)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  tenants    Tenant[]

  @@index([entityType, isActive, sortOrder])
}

enum PackageDiscountType {
  FIXED
  PERCENT
}

model SubscriptionPackage {
  id                       String                @id @default(cuid())
  code                     String                @unique
  name                     String
  description              String?
  priceCents               Int                   @default(0)
  currency                 String                @default("THB")
  billingInterval          String                @default("MONTHLY")
  discountType             PackageDiscountType?
  discountValue            Int                   @default(0)
  maxProjects              Int                   @default(1)
  maxUsers                 Int                   @default(5)
  additionalUserPriceCents Int                   @default(0)
  features                 String[]
  isActive                 Boolean               @default(true)
  isDefault                Boolean               @default(false)
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt

  tenants Tenant[]
  billingPeriods TenantBillingPeriod[]

  @@index([isActive, isDefault])
  @@index([createdAt])
}

model TenantBillingEvent {
  id          String                 @id @default(cuid())
  tenantId    String
  actorUserId String?
  type        TenantBillingEventType
  payloadJson Json?
  createdAt   DateTime               @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor  User?  @relation("BillingEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([type, createdAt])
}

model TenantBillingPeriod {
  id          String                    @id @default(cuid())
  tenantId    String
  periodStart DateTime
  periodEnd   DateTime?
  packageId   String?
  packageCode String
  packageName String?
  amountCents Int
  currency    String                    @default("THB")
  status      TenantBillingPeriodStatus @default(AWAITING_PAYMENT)
  paidAt      DateTime?
  closedAt    DateTime?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  tenant   Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  package  SubscriptionPackage?   @relation(fields: [packageId], references: [id], onDelete: SetNull)
  payments TenantBillingPayment[]

  @@index([tenantId, periodStart])
  @@index([status, periodEnd])
}

model TenantBillingPayment {
  id                String                     @id @default(cuid())
  periodId          String
  tenantId          String
  status            TenantBillingPaymentStatus @default(PENDING)
  slipFileName      String
  slipStoredName    String
  slipMimeType      String?
  slipSizeBytes     Int?
  submittedByUserId String
  reviewedByUserId  String?
  reviewNote        String?
  submittedAt       DateTime                   @default(now())
  reviewedAt        DateTime?

  period      TenantBillingPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  submittedBy User                @relation("BillingPaymentSubmittedBy", fields: [submittedByUserId], references: [id], onDelete: Restrict)
  reviewedBy  User?               @relation("BillingPaymentReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([periodId, status])
  @@index([tenantId, submittedAt])
}

model TenantMembership {
  id         String     @id @default(cuid())
  tenantId   String
  userId     String
  role       TenantRole @default(MEMBER)
  nickname   String?
  jobTitle   String?
  department String?
  isActive  Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@index([tenantId, role])
}

model UserInvitation {
  id             String     @id @default(cuid())
  tenantId       String
  email          String
  name           String
  nickname       String?
  phone          String?
  tenantRole     TenantRole @default(MEMBER)
  userRole       UserRole   @default(MEMBER)
  jobTitle       String
  department     String?
  tokenHash      String     @unique
  expiresAt      DateTime
  emailLastAttemptAt DateTime?
  emailSentAt     DateTime?
  emailLastError  String?
  acceptedAt     DateTime?
  acceptedUserId String?
  createdById    String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  tenant       Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy    User?  @relation("InvitationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  acceptedUser User?  @relation("InvitationAcceptedUser", fields: [acceptedUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, email])
  @@index([expiresAt])
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  userAgent  String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Project {
  id          String    @id @default(cuid())
  tenantId    String?
  code        String    @unique
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant      Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  meetings    Meeting[]
  actionItems ActionItem[]
  knowledgeChunks MeetingKnowledgeChunk[]
  askAiQueryLogs AskAiQueryLog[]
  reminderDigests ReminderDigest[]
  aiRunLogs AiRunLog[]
  knowledgeSources ProjectKnowledgeSource[]
  memoryItems ProjectMemoryItem[]
  generalNotes ProjectGeneralNote[]
  knowledgeImportJobs ProjectKnowledgeImportJob[]

  @@index([tenantId, createdAt])
}

model ProjectKnowledgeSource {
  id             String                         @id @default(cuid())
  tenantId       String?
  projectId      String
  sourceType     ProjectKnowledgeSourceType
  title          String
  contentText    String
  documentDate   DateTime?
  versionLabel   String?
  authorityLevel ProjectKnowledgeAuthorityLevel @default(SUPPORTING)
  status         ProjectKnowledgeSourceStatus   @default(UPLOADED)
  uploadedById   String?
  createdAt      DateTime                       @default(now())
  updatedAt      DateTime                       @updatedAt

  project        Project                        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tenant         Tenant?                        @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  uploadedBy     User?                          @relation("ProjectKnowledgeSourceUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  extractions    ProjectKnowledgeExtraction[]
  memoryItems    ProjectMemoryItem[]

  @@index([projectId, status])
  @@index([tenantId, createdAt])
  @@index([sourceType])
}

model ProjectKnowledgeExtraction {
  id                String   @id @default(cuid())
  sourceId          String
  extractionJson    Json
  confidence        String
  model             String?
  promptVersion     String?
  createdAt         DateTime @default(now())

  source            ProjectKnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId, createdAt])
}

model ProjectKnowledgeImportJob {
  id               String                   @id @default(uuid())
  kind             KnowledgeImportJobKind
  projectId        String
  userId           String
  fileName         String
  sourceId         String?
  status           KnowledgeImportJobStatus @default(QUEUED)
  stage            String                   @default("queued")
  detail           String?
  currentChunk     Int?
  totalChunks      Int?
  successfulChunks Int?
  error            String?
  resultJson       Json?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  completedAt      DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([projectId, createdAt])
}

model ProjectMemoryItem {
  id             String                  @id @default(cuid())
  tenantId       String?
  projectId      String
  sourceId       String?
  type           ProjectMemoryItemType
  title          String
  content        String
  status         ProjectMemoryItemStatus @default(DRAFT)
  effectiveDate  DateTime?
  supersededById String?
  approvedById   String?
  approvedAt     DateTime?
  metadataJson   Json?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  project        Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tenant         Tenant?                 @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  source         ProjectKnowledgeSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  approvedBy     User?                   @relation("ProjectMemoryItemApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  supersededBy   ProjectMemoryItem?      @relation("ProjectMemorySupersession", fields: [supersededById], references: [id], onDelete: SetNull)
  supersedes     ProjectMemoryItem[]     @relation("ProjectMemorySupersession")

  @@index([projectId, type, status])
  @@index([tenantId, createdAt])
  @@index([sourceId])
  @@index([approvedById])
}

model ProjectGeneralNote {
  id         String   @id @default(cuid())
  tenantId   String?
  projectId  String
  authorId   String
  title      String
  content    String
  visibility ProjectGeneralNoteVisibility @default(PUBLIC)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author     User     @relation("ProjectGeneralNoteAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([projectId, createdAt])
  @@index([projectId, visibility, createdAt])
  @@index([tenantId, createdAt])
  @@index([authorId, createdAt])
}

model FeelingLog {
  id          String     @id @default(cuid())
  tenantId    String
  authorId    String
  content     String
  emoji       String?
  isPrivate   Boolean    @default(true)
  processedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tenant     Tenant     @relation("FeelingLogTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  author     User       @relation("FeelingLogAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  mentions   FeelingLogMention[]
  analyses   FeelingLogAnalysis[]

  @@index([tenantId, createdAt])
  @@index([tenantId, processedAt])
  @@index([authorId, createdAt])
}

model FeelingLogMention {
  id              String     @id @default(cuid())
  feelingLogId    String
  mentionedUserId  String
  mentionLabel    String
  createdAt       DateTime   @default(now())

  feelingLog      FeelingLog @relation(fields: [feelingLogId], references: [id], onDelete: Cascade)
  mentionedUser   User       @relation("FeelingLogMentionTarget", fields: [mentionedUserId], references: [id], onDelete: Cascade)

  @@index([feelingLogId])
  @@index([mentionedUserId, createdAt])
}

model FeelingLogAnalysis {
  id             String                  @id @default(cuid())
  feelingLogId   String
  audience       FeelingLogAnalysisAudience
  targetUserId   String?
  title          String
  summary        String
  interpretation String
  recommendation String?
  riskLevel      String?
  model          String?
  promptVersion  String?
  createdAt      DateTime                @default(now())

  feelingLog     FeelingLog              @relation(fields: [feelingLogId], references: [id], onDelete: Cascade)
  targetUser     User?                   @relation("FeelingLogAnalysisTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([feelingLogId, audience, createdAt])
  @@index([targetUserId, createdAt])
}

model Meeting {
  id            String       @id @default(cuid())
  projectId     String
  title         String
  agenda        String?
  sessionAt     DateTime
  timezone      String?
  status        MeetingStatus @default(SCHEDULED)
  summary       String
  transcript    String?
  createdById   String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy     User         @relation("MeetingCreator", fields: [createdById], references: [id])
  minutes       MinuteEntry[]
  actionItems   ActionItem[]
  embeddings    EmbeddingChunk[]
  participants  MeetingParticipant[]
  artifacts     MeetingArtifact[]
  minuteDrafts  MinuteDraft[]
  minuteVersions MinuteVersion[]
  decisions     Decision[]
  knowledgeChunks MeetingKnowledgeChunk[]
  askAiQueryLogs AskAiQueryLog[]
  aiRunLogs AiRunLog[]

  @@index([projectId, sessionAt])
}

model AiRunLog {
  id                String         @id @default(cuid())
  operation         AiRunOperation
  status            AiRunStatus
  userId            String?
  projectId         String?
  meetingId         String?
  model             String?
  promptVersion     String?
  durationMs        Int?
  retrievedIdsJson  Json?
  traceJson         Json?
  errorMessage      String?
  createdAt         DateTime       @default(now())

  user              User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  project           Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  meeting           Meeting?       @relation(fields: [meetingId], references: [id], onDelete: SetNull)

  @@index([operation, createdAt])
  @@index([projectId, createdAt])
  @@index([meetingId, createdAt])
}

model AskAiQueryLog {
  id                   String    @id @default(cuid())
  userId               String
  projectId            String?
  meetingId            String?
  question             String
  answer               String
  confidence           String
  model                String?
  retrievedEvidenceIds Json
  usedEvidenceJson     Json
  retrievalDebugJson   Json?
  sentimentProcessedAt DateTime?
  sentimentBatchId     String?
  sentimentWindowStart DateTime?
  sentimentWindowEnd   DateTime?
  sentimentProcessingStatus SentimentProcessingStatus @default(PENDING)
  createdAt            DateTime  @default(now())

  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project              Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  meeting              Meeting?  @relation(fields: [meetingId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([projectId, createdAt])
  @@index([meetingId, createdAt])
  @@index([sentimentProcessingStatus, createdAt])
}

model MeetingParticipant {
  id           String                 @id @default(cuid())
  meetingId    String
  userId       String?
  displayName  String?
  email        String?
  role         MeetingParticipantRole @default(ATTENDEE)
  roleLabel    String?
  attended     Boolean                @default(true)
  attendanceStatus MeetingAttendanceStatus?
  createdAt    DateTime               @default(now())

  meeting      Meeting                @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user         User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([meetingId, role])
  @@index([userId])
}

model MeetingArtifact {
  id           String            @id @default(cuid())
  meetingId    String
  type         MeetingArtifactType
  sourceType   MeetingArtifactSourceType @default(OTHER)
  title        String?
  contentText  String?
  fileUrl      String?
  mimeType     String?
  sourceRef    String?
  createdById  String?
  createdAt    DateTime          @default(now())

  meeting      Meeting           @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  createdBy    User?             @relation(fields: [createdById], references: [id], onDelete: SetNull)
  minuteDrafts MinuteDraft[]

  @@index([meetingId, type])
  @@index([createdById])
}

model MinuteDraft {
  id                 String           @id @default(cuid())
  meetingId          String
  sourceArtifactId   String?
  status             MinuteDraftStatus @default(DRAFT)
  summary            String?
  keyPointsJson      Json?
  decisionsJson      Json?
  actionItemsJson    Json?
  risksJson          Json?
  openQuestionsJson  Json?
  generatedBy        MinuteDraftGeneratedBy @default(AI)
  generationMetaJson Json?
  rawModelOutputJson Json?
  parseErrorsJson    Json?
  llmModel           String?
  extractionRunId    String?
  createdById        String?
  generatedAt        DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  meeting            Meeting          @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  sourceArtifact     MeetingArtifact? @relation(fields: [sourceArtifactId], references: [id], onDelete: SetNull)
  createdBy          User?            @relation(fields: [createdById], references: [id], onDelete: SetNull)
  minuteVersions     MinuteVersion[]
  actionItems        ActionItem[]

  @@index([meetingId, status])
  @@index([generatedAt])
  @@index([createdById])
}

model MinuteVersion {
  id              String             @id @default(cuid())
  meetingId       String
  draftId         String?
  versionNo       Int
  status          MinuteVersionStatus @default(APPROVED)
  summary         String
  keyPointsJson   Json?
  decisionsJson   Json?
  actionItemsJson Json?
  risksJson       Json?
  snapshotJson    Json
  approvedById    String
  approvedAt      DateTime           @default(now())
  createdAt       DateTime           @default(now())

  meeting         Meeting            @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  draft           MinuteDraft?       @relation(fields: [draftId], references: [id], onDelete: SetNull)
  approvedBy      User               @relation("MinuteVersionApprover", fields: [approvedById], references: [id], onDelete: Restrict)
  decisions       Decision[]
  actionItems     ActionItem[]
  knowledgeChunks MeetingKnowledgeChunk[]

  @@unique([meetingId, versionNo])
  @@index([meetingId, approvedAt])
}

model MeetingKnowledgeChunk {
  id             String                   @id @default(cuid())
  chunkKey       String                   @unique
  projectId      String
  meetingId      String
  minuteVersionId String
  sourceType     KnowledgeChunkSourceType
  sourceRowId    String?
  textContent    String
  metadataJson   Json?
  embeddingJson  Json?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  project        Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  meeting        Meeting                  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  minuteVersion  MinuteVersion            @relation(fields: [minuteVersionId], references: [id], onDelete: Cascade)

  @@index([projectId, sourceType])
  @@index([meetingId, sourceType])
  @@index([minuteVersionId])
  @@index([sourceRowId])
}

model Decision {
  id              String         @id @default(cuid())
  meetingId       String
  minuteVersionId String?
  title           String
  detail          String?
  ownerId         String?
  dueDate         DateTime?
  status          DecisionStatus @default(ACTIVE)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  meeting         Meeting        @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  minuteVersion   MinuteVersion? @relation(fields: [minuteVersionId], references: [id], onDelete: SetNull)
  owner           User?          @relation("DecisionOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([meetingId, status])
  @@index([ownerId])
  @@index([dueDate])
}

model MinuteEntry {
  id          String    @id @default(cuid())
  meetingId   String
  section     String
  content     String
  createdAt   DateTime  @default(now())

  meeting     Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model ActionItem {
  id             String       @id @default(cuid())
  projectId      String
  meetingId      String?
  minuteDraftId  String?
  minuteVersionId String?
  task           String
  detail         String?
  assigneeId     String
  ownerDisplayName String?
  dueDate        DateTime
  priority       ActionItemPriority @default(MEDIUM)
  status         ActionStatus @default(TODO)
  source         ActionItemSource @default(MANUAL)
  sourceDraftItemRef String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  completedAt    DateTime?

  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  meeting        Meeting?     @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  minuteDraft    MinuteDraft? @relation(fields: [minuteDraftId], references: [id], onDelete: SetNull)
  minuteVersion  MinuteVersion? @relation(fields: [minuteVersionId], references: [id], onDelete: SetNull)
  assignee       User         @relation("ActionAssignee", fields: [assigneeId], references: [id])
  notifications  Notification[]
  statusHistory  ActionItemStatusHistory[]
  reminderLogs   ReminderLog[]

  @@index([projectId, status, dueDate])
  @@index([meetingId, status, dueDate])
  @@index([assigneeId, status])
  @@index([assigneeId, status, dueDate])
}

model ActionItemStatusHistory {
  id             String       @id @default(cuid())
  actionItemId   String
  fromStatus     ActionStatus?
  toStatus       ActionStatus
  changedById    String?
  note           String?
  changedAt      DateTime     @default(now())

  actionItem     ActionItem   @relation(fields: [actionItemId], references: [id], onDelete: Cascade)
  changedBy      User?        @relation("ActionItemStatusChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([actionItemId, changedAt])
  @@index([changedById])
}

model Notification {
  id            String       @id @default(cuid())
  actionItemId  String
  userId        String
  type          ReminderType
  message       String
  sentAt        DateTime     @default(now())

  actionItem    ActionItem   @relation(fields: [actionItemId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([actionItemId, userId, type])
}

model ReminderLog {
  id               String               @id @default(cuid())
  actionItemId     String
  reminderType     ReminderLogType
  sentToUserId     String?
  sentToDisplayName String?
  message          String
  deliveryStatus   ReminderDeliveryStatus
  channelMetaJson  Json?
  sentAt           DateTime             @default(now())

  actionItem       ActionItem           @relation(fields: [actionItemId], references: [id], onDelete: Cascade)
  sentToUser       User?                @relation(fields: [sentToUserId], references: [id], onDelete: SetNull)

  @@index([actionItemId, reminderType, sentAt])
  @@index([sentToUserId, sentAt])
}

model ReminderDigest {
  id                 String   @id @default(cuid())
  projectId          String
  windowStart        DateTime
  windowEnd          DateTime
  totalOpen          Int
  totalDueSoon       Int
  totalOverdue       Int
  totalEscalated     Int
  overdueByOwnerJson Json?
  itemsJson          Json?
  createdAt          DateTime @default(now())

  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([createdAt])
}

model MorningBriefing {
  id             String                 @id @default(cuid())
  tenantId       String
  userId         String
  briefingDate   DateTime
  status         MorningBriefingStatus  @default(GENERATED)
  roleScope      String
  headline       String
  summary        String
  sectionsJson   Json
  evidenceJson   Json
  actionItemIdsJson Json
  model          String?
  promptVersion  String?
  generatedAt    DateTime               @default(now())
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User                   @relation("MorningBriefingUser", fields: [userId], references: [id], onDelete: Cascade)
  acknowledgements MorningBriefingAcknowledgement[]

  @@unique([tenantId, userId, briefingDate])
  @@index([userId, generatedAt])
  @@index([tenantId, generatedAt])
}

model MorningBriefingAcknowledgement {
  id             String                  @id @default(cuid())
  briefingId     String
  userId         String
  mood           MorningBriefingAckMood
  score          Int
  reviewAgain    Boolean?
  createdAt      DateTime                @default(now())

  briefing       MorningBriefing         @relation(fields: [briefingId], references: [id], onDelete: Cascade)
  user           User                    @relation("MorningBriefingAckUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([briefingId, userId])
  @@index([userId, createdAt])
  @@index([score, createdAt])
}

model NotificationSetting {
  id           String   @id @default(cuid())
  userId       String   @unique
  inAppEnabled Boolean  @default(true)
  emailEnabled Boolean  @default(false)
  pushEnabled  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id             String    @id @default(cuid())
  userId         String
  endpoint       String    @unique
  p256dh         String
  auth           String
  expirationTime DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmbeddingChunk {
  id          String   @id @default(cuid())
  meetingId   String
  chunkText   String
  vector      Json?
  sourceType  String
  createdAt   DateTime @default(now())

  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

model CommunicationSentimentSnapshot {
  id            String                 @id @default(cuid())
  tenantId      String
  memberUserId  String?
  windowStart   DateTime
  windowEnd     DateTime
  sampleCount   Int
  moodScore     Int
  stressScore   Int
  frictionScore Int
  urgencyScore  Int
  confidence    String
  summary       String
  themesJson    Json
  signalsJson   Json
  caveatsJson   Json
  suggestionsJson Json
  moodState     CommunicationMoodState
  batchId       String
  model         String?
  createdAt     DateTime               @default(now())

  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberUser    User?                  @relation("MemberSentimentSnapshots", fields: [memberUserId], references: [id], onDelete: SetNull)
  sources       CommunicationSentimentSource[]

  @@index([tenantId, createdAt])
  @@index([tenantId, memberUserId, createdAt])
  @@index([batchId])
}

model CommunicationSentimentSource {
  id               String                           @id @default(cuid())
  snapshotId       String
  sourceType       CommunicationSentimentSourceType
  sourceId         String
  messageCreatedAt DateTime
  includedAt       DateTime                         @default(now())

  snapshot         CommunicationSentimentSnapshot   @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@index([sourceType, sourceId])
}
